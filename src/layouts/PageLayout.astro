---
import DefaultLayout from '@layouts/DefaultLayout.astro'
import Breadcrumbs from '@components/Breadcrumbs.astro'

/**
 * Layout for standalone content pages (housing-crisis, who-we-are, etc.).
 * Provides the same full-height snap sections + scroll-reveal behaviour as the
 * homepage, plus an optional breadcrumb trail. Drop `.section` blocks into the
 * default slot; end the page with a `.section.section--flow` so the footer is
 * reachable.
 */
interface Crumb {
  label: string
  href?: string
}

interface Props {
  title: string
  description?: string
  crumbs?: Crumb[]
}

const { title, description, crumbs } = Astro.props
---

<DefaultLayout title={title} description={description}>
  <!-- Enable reveal-on-scroll only when JS is available (no-JS shows all content) -->
  <script is:inline>
    document.documentElement.classList.add('js-reveal')
  </script>

  {crumbs && crumbs.length > 0 && <Breadcrumbs crumbs={crumbs} />}

  <slot />
</DefaultLayout>

<script>
  // Reveal-on-scroll: sections fade + bounce up as they enter the viewport.
  const setupReveal = () => {
    const items = Array.from(document.querySelectorAll<HTMLElement>('[data-reveal]'))
    if (!items.length) return

    const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches

    if (prefersReducedMotion || !('IntersectionObserver' in window)) {
      items.forEach((item) => item.classList.add('is-visible'))
      return
    }

    const observer = new IntersectionObserver(
      (entries, obs) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add('is-visible')
            obs.unobserve(entry.target)
          }
        })
      },
      { threshold: 0.12, rootMargin: '0px 0px -8% 0px' },
    )

    items.forEach((item) => observer.observe(item))
  }

  document.addEventListener('astro:page-load', setupReveal)
</script>
