---
import { Link } from 'accessible-astro-components'

const currentYear = new Date().getFullYear()
---

<footer>
  <section class="py-8">
    <div class="container flex flex-col gap-4 md:flex-row md:justify-between">
      <p>
        &copy; {currentYear} Flint Hills Tenants United. Solidarity, not charity.
      </p>
      <p>
        Built with <Link href="https://astro.build/">Astro</Link> and the <Link
          href="https://accessible-astro.incluud.dev/">Accessible Astro</Link
        > starter.
      </p>
    </div>
  </section>
</footer>

<style>
  footer section {
    border-top: 1px solid var(--border-color-subtle);
  }
</style>
