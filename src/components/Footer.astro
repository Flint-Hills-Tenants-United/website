---
import { Link } from 'accessible-astro-components'

const currentYear = new Date().getFullYear()
---

<footer>
  <section class="py-8 space-content">
    <nav class="container" aria-label="Footer">
      <ul class="footer-nav">
        <li><Link href="/" class="plain">Home</Link></li>
        <li><Link href="/housing-crisis" class="plain">Housing Crisis</Link></li>
        <li><Link href="/who-we-are" class="plain">Who We Are</Link></li>
        <li><Link href="/tenant-rights" class="plain">Tenant Rights</Link></li>
        <li><Link href="/connect" class="plain">Connect With Us</Link></li>
      </ul>
    </nav>
    <div class="container flex flex-col gap-4 md:flex-row md:justify-between">
      <p>
        &copy; {currentYear} Flint Hills Tenants United. Solidarity, not charity.
      </p>
      <p>
        Built with <Link href="https://astro.build/">Astro</Link> and the <Link
          href="https://accessible-astro.incluud.dev/">Accessible Astro</Link
        > starter.
      </p>
    </div>
  </section>
</footer>

<style>
  footer section {
    border-top: 1px solid var(--border-color-subtle);
  }
</style>
