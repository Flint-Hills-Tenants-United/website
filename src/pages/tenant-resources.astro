---
import PageLayout from '@layouts/PageLayout.astro'
import { Heading } from 'accessible-astro-components'
import { Icon } from 'astro-icon/components'

// Icon shown next to each link/contact row, chosen by its `type`.
const linkIcon = {
  website: 'lucide:external-link',
  pdf: 'lucide:file-text',
  email: 'lucide:mail',
  phone: 'lucide:phone',
  address: 'lucide:map-pin',
}

const resources = [
  {
    icon: 'lucide:scale',
    title: 'Kansas Legal Services',
    links: [
      { type: 'phone', label: '316-267-3975'},
      { type: 'website', label: 'Website', href: 'https://www.kansaslegalservices.org/' },
    ],
  },
  {
    icon: 'lucide:life-buoy',
    title: 'Manhattan Emergency Center, Inc.',
    links: [
      { type: 'phone', label: '(785) 537-3113' },
      { type: 'email', label: 'info@mesikansas.org', href: 'mailto:info@mesikansas.org' },
      { type: 'website', label: 'Website', href: 'http://www.mesikansas.org/' },
      { type: 'address', label: '416 S. 4th St. Manhattan, Kansas 66502' },      
    ],
  },
  {
    icon: 'lucide:info',
    title: 'Kansas Housing Resources Corporation',
    links: [
      { type: 'phone', label: '(785) 217-2001' },
      { type: 'email', label: 'info@kshousingcorp.org', href: 'mailto:info@kshousingcorp.org' },
      { type: 'website', label: 'Website', href: 'https://kshousingcorp.org/' },
    ],
  },
  {
    icon: 'lucide:info',
    title: 'HUD Kansas',

    links: [
      { type: 'website', label: 'Website', href: 'https://www.hud.gov/states/kansas' },
    ],
  },
  {
    icon: 'lucide:book-open',
    title: 'Kansas Tenants Handbook',

    links: [
      { type: 'pdf', label: 'Kansas Tenants Handbook (PDF)', href: 'https://www.kansaslegalservices.org/files/THB.pdf' },
    ],
  },
    {
    icon: 'lucide:scale',
    title: 'Manhattan Fair Housing',

    links: [
      { type: 'website', label: 'Fair Housing for Landlords & Tenants', href: 'https://www.flinthillsdiscovery.org/1757/Fair-Housing-for-Landlords-Tenants' },
    ],
  },
]
---

<PageLayout
  title="Kansas Tenant Resources"
  description="A directory of legal help, emergency assistance, and organizing support for renters in Kansas and the Flint Hills."
  crumbs={[{ label: 'Home', href: '/' }, { label: 'Kansas Tenant Resources' }]}
>
  <header class="resources-head">
    <div class="container narrow space-content">
      <Heading level="h1" class="page-title text-balance">Kansas Tenant Resources</Heading>
      <p class="lead text-balance">
        Legal help, emergency assistance, and organizing support for renters. Reach out to any of these directly.
      </p>
    </div>
  </header>

  <div class="resources">
    <div class="container">
      <ul class="feature-grid" role="list">
        {
          resources.map((resource) => (
            <li class="feature-card space-content-2xs">
              <span class="feature-card__icon" aria-hidden="true">
                <Icon name={resource.icon} />
              </span>
              <Heading level="h2" size="h5">
                {resource.title}
              </Heading>
              <p>{resource.description}</p>
              <ul class="resource-links" role="list">
                {resource.links.map((link) =>
                  link.href ? (
                    <li>
                      <a
                        href={link.href}
                        class="plain"
                        {...(link.type === 'website' || link.type === 'pdf'
                          ? { target: '_blank', rel: 'noopener' }
                          : {})}
                      >
                        <Icon name={linkIcon[link.type]} aria-hidden="true" />
                        <span>{link.label}</span>
                      </a>
                    </li>
                  ) : (
                    <li>
                      <span class="resource-links__static">
                        <Icon name={linkIcon[link.type]} aria-hidden="true" />
                        <span>{link.label}</span>
                      </span>
                    </li>
                  ),
                )}
              </ul>
            </li>
          ))
        }
      </ul>
    </div>
  </div>
</PageLayout>

<style lang="scss">
  // A normal scrolling page (no full-height snap sections), just a header and a
  // grid of resource cards.
  .resources-head {
    padding-block: var(--space-2xl) var(--space-l);
  }

  .resources {
    padding-block-end: var(--space-3xl);
  }

  // Stack of links / contact rows inside each card.
  .resource-links {
    display: grid;
    gap: var(--space-3xs);
    margin: 0;
    margin-block-start: var(--space-xs);
    padding: 0;
    list-style: none;
  }

  .resource-links a,
  .resource-links__static {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2xs);
    font-weight: 600;
    line-height: 1.3;
    color: var(--color-neutral-100);
  }

  // `.plain` opts links out of the thick in-text underline; add a subtle one on hover.
  .resource-links a {
    text-decoration: underline;
    text-decoration-color: transparent;
    text-underline-offset: 3px;
    transition: text-decoration-color var(--animation-speed-fast) var(--cubic-bezier);
  }

  .resource-links a:where(:hover, :focus-visible) {
    text-decoration-color: currentColor;
  }

  .resource-links :global(svg) {
    inline-size: 1.1em;
    block-size: 1.1em;
    flex-shrink: 0;
    color: var(--color-neutral-100);
  }
</style>
