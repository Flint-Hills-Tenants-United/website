---
import DefaultLayout from '@layouts/DefaultLayout.astro'
import { Heading } from 'accessible-astro-components'
import { Icon } from 'astro-icon/components'
import { Image } from 'astro:assets'
import themeConfig from '@theme-config'

const whatWeDo = [
  {
    icon: 'lucide:megaphone',
    title: 'Organize',
    text: 'We bring neighbors together building by building and block by block, so no renter has to face a landlord alone.',
  },
  {
    icon: 'lucide:scale',
    title: 'Advocate',
    text: 'We push for stronger tenant protections and fair housing policy across Manhattan and the Flint Hills.',
  },
  {
    icon: 'lucide:book-open',
    title: 'Educate',
    text: 'We share know-your-rights resources and practical tools so tenants can act with confidence.',
  },
]

const rights = [
  'The right to a safe, habitable home with working heat, water, and utilities.',
  'The right to proper written notice before a rent increase or eviction.',
  'The right to have repairs made and to withhold in limited, lawful circumstances.',
  'The right to organize with your neighbors free from retaliation.',
  'The right to the return of your security deposit, with itemized deductions.',
  'The right to privacy and reasonable notice before a landlord enters.',
]
---

<DefaultLayout title="Flint Hills Tenants United" useTitleTemplate={false}>
  <!-- Enable reveal-on-scroll only when JS is available (no-JS shows all content) -->
  <script is:inline>
    document.documentElement.classList.add('js-reveal')
  </script>

  <!-- Hero -->
  <section class="hero" data-reveal>
    <div class="container">
      <div class="hero__grid">
        <div class="hero__inner space-content center-text">
          <Heading level="h1" class="hero__title text-balance">Housing is a right. Together we defend it.</Heading>
          <p class="hero__lead text-balance">
            Flint Hills Tenants United is a tenant-led union of neighbors organizing for safe, affordable, and dignified
            housing. When renters stand together, we win.
          </p>
          <div class="btn-group btn-group--center">
            <a href="#know-your-rights" class="btn">Know Your Rights</a>
          </div>
        </div>
        {
          themeConfig.logo && (
            <div class="hero__media">
              <Image
                src={themeConfig.logo}
                alt="Flint Hills Tenants United emblem: a raised fist holding keys"
                width={420}
                height={420}
                densities={[2]}
                loading="eager"
              />
            </div>
          )
        }
      </div>
    </div>
  </section>

    <!-- Know your rights -->
  <section id="know-your-rights" class="section" data-reveal>
    <div class="container split-grid">
      <div class="space-content">
        <p class="eyebrow">Know your rights</p>
        <Heading level="h2">You have more power than you think</Heading>
        <p>
          Kansas renters are protected by law but those protections only matter when tenants know them and act on
          them. Here are some of the rights every tenant should keep close.
        </p>
        <div class="btn-group">
          <a href="/tenant-rights" class="btn">Learn More</a>
        </div>
      </div>
      <ul class="rights-list" role="list">
        {
          rights.map((right) => (
            <li>
              <Icon name="lucide:check" aria-hidden="true" />
              <span>{right}</span>
            </li>
          ))
        }
      </ul>
    </div>
  </section>

  <!-- Mission -->
  <section class="section" data-reveal>
    <div class="container narrow center-text">
      <p class="mission text-balance">
        We believe every person deserves a home they can afford and a landlord who treats them with respect. We build
        the collective power to make that real not through favors, but through organized tenants.
      </p>
      <div class="btn-group btn-group--center">
        <a href="/who-we-are" class="btn btn--ghost">Who We Are</a>
      </div>
    </div>
  </section>

  <!-- What we do -->
  <section id="what-we-do" class="section" data-reveal>
    <div class="container space-content">
      <div class="section__head">
        <p class="eyebrow">What we do</p>
        <Heading level="h2">Three ways we build tenant power</Heading>
      </div>
      <ul class="feature-grid" role="list">
        {
          whatWeDo.map((item) => (
            <li class="feature-card space-content-2xs">
              <span class="feature-card__icon" aria-hidden="true">
                <Icon name={item.icon} />
              </span>
              <Heading level="h3" size="h5">
                {item.title}
              </Heading>
              <p>{item.text}</p>
            </li>
          ))
        }
      </ul>
    </div>
  </section>



  <!-- Call to action -->
  <section id="get-involved" class="section" data-reveal>
    <div class="container">
      <div class="cta-panel center-text space-content">
        <Heading level="h2">Ready to stand with your neighbors?</Heading>
        <p class="cta__lead">
          Whether you are facing a problem with your landlord or you just want to help build the union, there is a
          place for you here. It starts with a conversation.
        </p>
        <div class="btn-group btn-group--center">
          <a href="/connect" class="btn">Join the union</a>
          <a href="/connect" class="btn btn--ghost">Volunteer</a>
        </div>
      </div>
    </div>
  </section>

  <!-- Contact -->
  <section id="contact" class="section section--flow" data-reveal>
    <div class="container narrow center-text space-content">
      <p class="eyebrow">Contact</p>
      <Heading level="h2">Get in touch</Heading>
      <p>Reach out and an organizer will get back to you. Everything you share stays confidential.</p>
      <p class="contact-email">
        <Icon name="lucide:mail" aria-hidden="true" />
        <a href="mailto:info@flinthillstenantsunited.org">info@flinthillstenantsunited.org</a>
      </p>
    </div>
  </section>
</DefaultLayout>

<script>
  // Reveal-on-scroll: sections fade + bounce up as they enter the viewport.
  const setupReveal = () => {
    const items = Array.from(document.querySelectorAll<HTMLElement>('[data-reveal]'))
    if (!items.length) return

    const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches

    if (prefersReducedMotion || !('IntersectionObserver' in window)) {
      items.forEach((item) => item.classList.add('is-visible'))
      return
    }

    const observer = new IntersectionObserver(
      (entries, obs) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add('is-visible')
            obs.unobserve(entry.target)
          }
        })
      },
      { threshold: 0.12, rootMargin: '0px 0px -8% 0px' },
    )

    items.forEach((item) => observer.observe(item))
  }

  document.addEventListener('astro:page-load', setupReveal)
</script>

<style lang="scss">
  @use 'scss/base/breakpoint' as *;

  // Shared section/button/card styling now lives in scss/base/_page.scss so it
  // can be reused by the standalone pages. Only home-specific styles remain here.

  // Hero
  .hero {
    padding-block: var(--space-3xl) var(--space-2xl);
  }

  .hero__grid {
    display: grid;
    gap: var(--space-xl);
    align-items: center;
    grid-template-columns: 1fr;

    @include breakpoint('l') {
      grid-template-columns: 1.15fr 0.85fr;
    }
  }

  .hero__inner {
    max-inline-size: 55ch;
    margin-inline: auto;
  }

  .hero__media {
    display: flex;
    justify-content: center;
    order: -1; // logo on top when stacked on small screens

    @include breakpoint('l') {
      order: 0;
    }

    :global(img) {
      inline-size: min(100%, 420px);
      block-size: auto;
    }
  }

  .hero__title {
    font-size: var(--font-size-7);
    line-height: 1.05;
  }

  .hero__lead {
    font-size: var(--font-size-2);
    max-inline-size: 46ch;
    margin-inline: auto;
  }

  // Mission
  .mission {
    font-size: var(--font-size-3);
    line-height: 1.35;
    text-wrap: balance;
  }
</style>
