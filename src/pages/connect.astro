---
import PageLayout from '@layouts/PageLayout.astro'
import { Heading } from 'accessible-astro-components'
import { Icon } from 'astro-icon/components'

const ways = [
  {
    icon: 'lucide:user-plus',
    title: 'Join the union',
    text: 'Become a member and stand with renters across the Flint Hills. Every new member makes us stronger.',
  },
  {
    icon: 'lucide:megaphone',
    title: 'Organize your building',
    text: 'Facing a bad landlord or a rent hike? We’ll help you bring your neighbors together and respond as one.',
  },
  {
    icon: 'lucide:hand-heart',
    title: 'Volunteer',
    text: 'Lend a few hours — door-knocking, translation, research, childcare, design. There’s a task for every skill.',
  },
]
---

<PageLayout
  title="Connect With Us"
  description="Join Flint Hills Tenants United, organize your building, or volunteer. Reach out and an organizer will get back to you."
  crumbs={[{ label: 'Home', href: '/' }, { label: 'Connect With Us' }]}
>
  <!-- Intro -->
  <section class="page-hero center-text" data-reveal>
    <div class="container narrow space-content">
      <p class="eyebrow">
        <Icon name="lucide:mail" aria-hidden="true" />
        Connect with us
      </p>
      <Heading level="h1" class="page-title text-balance">It starts with a conversation.</Heading>
      <p class="lead text-balance">
        Whether you’re dealing with a problem right now or you just want to help build the union, there’s a place for
        you here. Reach out — everything you share stays confidential.
      </p>
      <p class="contact-email">
        <Icon name="lucide:mail" aria-hidden="true" />
        <a href="mailto:info@flinthillstenantsunited.org">info@flinthillstenantsunited.org</a>
      </p>
    </div>
  </section>

  <!-- Ways to plug in -->
  <section class="section" data-reveal>
    <div class="container space-content">
      <div class="section__head">
        <p class="eyebrow">Ways to plug in</p>
        <Heading level="h2">Find your role</Heading>
      </div>
      <ul class="feature-grid" role="list">
        {
          ways.map((way) => (
            <li class="feature-card space-content-2xs">
              <span class="feature-card__icon" aria-hidden="true">
                <Icon name={way.icon} />
              </span>
              <Heading level="h3" size="h5">
                {way.title}
              </Heading>
              <p>{way.text}</p>
            </li>
          ))
        }
      </ul>
    </div>
  </section>

  <!-- Contact CTA -->
  <section class="section section--flow" data-reveal>
    <div class="container">
      <div class="cta-panel center-text space-content">
        <p class="eyebrow">Get in touch</p>
        <Heading level="h2">Send us a note</Heading>
        <p class="cta__lead">
          Tell us a little about your situation or how you’d like to help, and an organizer will follow up. No pressure,
          no commitment — just a first step.
        </p>
        <p class="contact-email">
          <Icon name="lucide:mail" aria-hidden="true" />
          <a href="mailto:info@flinthillstenantsunited.org">info@flinthillstenantsunited.org</a>
        </p>
        <div class="btn-group btn-group--center">
          <a href="/tenant-rights" class="btn btn--ghost">Know your rights first</a>
        </div>
      </div>
    </div>
  </section>
</PageLayout>
